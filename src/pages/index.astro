---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import PostList from '../components/PostList.astro';
import SectionList from "../components/SectionList.astro";

import { getCollection } from "astro:content";
import { getSite } from '../utils/consts';
import ProjectList from '../components/ProjectList.astro';
import Social from '../components/Social.astro';

const cv = (await getCollection("cv" as any)) as any[];

const site = await getSite();
---

<PageLayout
	title={site.author.name || 'Shubhom Srivastava'}
>
	<Hero
		title={site.author.name || 'Shubhom Srivastava'}
		description={site.author.bio || 'Welcome to my personal website.'}
		role={site.author.role}
		location={site.author.location}
		actions={[
			{ label: 'View Blog', href: '/blog' },
			{ label: 'Work Together!', href: 'https://cal.com/shubhom-srivastava/30min' },
		]}
	/>

	<Social class="mt-8" />

	            <!-- Experience & Skills -->
            {
                cv.filter(s => s.data.id === 'experience' || s.data.id === 'skills').map((section) => {
                    if (section.data.items) {
                        return (
                            <SectionList
                                heading={section.data.heading}
                                items={section.data.items}
                            />
                        );
                    }
                    return null;
                })
            }

	<ProjectList
		heading="Projects"
		limit={4}
		viewAllHref="/projects"
	/>

	            <!-- Education -->
            {
                cv.filter(s => s.data.id === 'education').map((section) => {
                    if (section.data.items) {
                        return (
                            <SectionList
                                heading={section.data.heading}
                                items={section.data.items}
                            />
                        );
                    }
                    return null;
                })
            }

	{/* TODO: Add blog posts and uncomment this section */}
	{/* Blog section hidden — uncomment when blog posts are added
	<PostList
		heading="Blog"
		limit={3}
		viewAllHref="/blog"
	/>
	*/}
		
</PageLayout>
